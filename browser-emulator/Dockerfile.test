FROM node:24-trixie AS test

WORKDIR /app
ENV NODE_ENV=test

RUN apt-get update && apt-get install -y procps curl linux-perf golang portaudio19-dev libcap2-bin && rm -rf /var/lib/apt/lists/* && setcap cap_perfmon,cap_sys_admin+ep "$(readlink -f /usr/bin/perf || echo /usr/bin/perf)"

# Build livekit-cli from upstream source with profiling patch and debug symbols
# (for perf profiling and go tool pprof)
RUN git clone https://github.com/livekit/livekit-cli.git /tmp/livekit-cli && \
    cd /tmp/livekit-cli && \
    git checkout v2.16.6 && \
    git submodule update --init --recursive
COPY vendor/livekit-cli-profiling.patch /tmp/livekit-cli/
RUN cd /tmp/livekit-cli && \
    git apply livekit-cli-profiling.patch && \
    go build -tags portaudio_system -ldflags=-s=false -o /usr/local/bin/lk ./cmd/lk && \
    rm -rf /tmp/livekit-cli

COPY index-mappings.json ./index-mappings.json

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

ENV COREPACK_HOME=/usr/local/share/corepack
RUN corepack enable && corepack prepare pnpm@10.30.3 --activate && pnpm install --frozen-lockfile

RUN mkdir -p /app/node_modules/.vitest && chown node:node /app/node_modules/.vitest

COPY --chown=node:node tsconfig.json tsconfig.test.json vitest.config.ts eslint.config.js ./
COPY --chown=node:node public ./public
COPY --chown=node:node public-lk ./public-lk
COPY --chown=node:node vendor ./vendor
COPY --chown=node:node src ./src
COPY --chown=node:node tests ./tests

RUN mkdir -p recordings/chrome recordings/qoe stats logs mediafiles && \
    chown node:node recordings/chrome recordings/qoe stats logs mediafiles

# Make /app writable by the node user so vitest can create temp config files
RUN chown node:node /app

CMD ["pnpm","run","test"]