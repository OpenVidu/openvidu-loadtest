{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Launch tests in Vagrant for Debugging",
			"type": "node",
			"request": "launch",
			"runtimeExecutable": "pnpm",
			"runtimeArgs": ["run", "test:all", "--debug"],
			"cwd": "${workspaceFolder}"
		},
		{
			"name": "Attach to Vagrant debug session",
			"type": "node",
			"request": "attach",
			"address": "127.0.0.1",
			"port": 9230,
			"timeout": 1200000,
			"localRoot": "${workspaceFolder}",
			"remoteRoot": "/opt/openvidu-loadtest/browser-emulator",
			"skipFiles": ["<node_internals>/**", "**/node_modules/**"]
		},
		{
			"name": "Attach: Debug QoE scripts",
			"type": "debugpy",
			"request": "attach",
			"connect": {
				"host": "localhost",
				"port": 5678
			},
			"pathMappings": [
				{
					"localRoot": "${workspaceFolder}",
					"remoteRoot": "/opt/openvidu-loadtest/browser-emulator"
				}
			],
			"justMyCode": false
		}
	]
}
