{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Launch tests in Vagrant for Debugging",
			"type": "node",
			"request": "launch",
			"runtimeExecutable": "pnpm",
			"runtimeArgs": ["run", "test:all:debug"],
			"cwd": "${workspaceFolder}"
		},
		{
			"name": "Attach to Vagrant debug session",
			"type": "node",
			"request": "attach",
			"address": "127.0.0.1",
			"port": 9230,
			"timeout": 600000,
			"localRoot": "${workspaceFolder}",
			"remoteRoot": "/opt/openvidu-loadtest/browser-emulator",
			"skipFiles": ["<node_internals>/**", "**/node_modules/**"]
		}
	],
	"compounds": [
		{
			"name": "Launch and Attach to Vagrant Tests",
			"configurations": [
				"Launch tests in Vagrant for Debugging",
				"Attach to Vagrant debug session"
			],
			"presentation": {
				"hidden": false,
				"group": "1",
				"order": 1
			},
			"stopAll": true
		}
	]
}
