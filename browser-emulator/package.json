{
  "name": "browser-emulator",
  "version": "4.0.0",
  "description": "Load testing tool for OpenVidu",
  "main": "server.ts",
  "engines": {
    "node": ">=24.14.0"
  },
  "type": "module",
  "scripts": {
    "start:prod": "node ./dist/server.js",
    "start:prod-livekit": "COM_MODULE=livekit node ./dist/server.js",
    "start:prod-firefox": "REAL_DRIVER=firefox node ./dist/server.js",
    "start:prod-livekit-firefox": "REAL_DRIVER=firefox COM_MODULE=livekit node ./dist/server.js",
    "start:dev-none": "APPLICATION_MODE=DEVELOPMENT ts-node ./src/server.ts",
    "start:dev-none-firefox": "APPLICATION_MODE=DEVELOPMENT REAL_DRIVER=firefox ts-node ./src/server.ts",
    "start:dev-livekit-firefox": "APPLICATION_MODE=DEVELOPMENT REAL_DRIVER=firefox COM_MODULE=livekit ts-node ./src/server.ts",
    "build": "tsc",
    "watch": "tsc -w",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest --config jest.config.ts --runInBand",
    "test:unit": "jest --config jest.config.ts --testPathPatterns=tests/unit --runInBand",
    "test:integration": "jest --config jest.config.ts --testPathPatterns=tests/integration --runInBand",
    "test:coverage": "jest --config jest.config.ts --runInBand --coverage --detectOpenHandles",
    "qoe": "ts-node ./src/utils/run-qoe-analysis.ts"
  },
  "author": "Carlos Santos & Iván Chicano",
  "license": "Apache 2.0",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.999.0",
    "@elastic/elasticsearch": "7.8.0",
    "async-mutex": "^0.5.0",
    "dockerode": "4.0.9",
    "express": "5.2.1",
    "livekit-server-sdk": "^2.15.0",
    "multer": "2.1.0",
    "node-cleanup": "^2.1.2",
    "node-os-utils": "^2.0.1",
    "p-limit": "^7.3.0",
    "selenium-webdriver": "4.41.0",
    "ws": "^8.19.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@tsconfig/node-ts": "^23.6.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/dockerode": "4.0.1",
    "@types/express": "5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "25.3.2",
    "@types/node-cleanup": "^2.1.5",
    "@types/selenium-webdriver": "4.35.5",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^30.2.0",
    "prettier": "3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "optionalDependencies": {
    "bufferutil": "^4.1.0"
  }
}
