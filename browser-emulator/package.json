{
	"name": "browser-emulator",
	"version": "4.0.0",
	"description": "Load testing tool for OpenVidu",
	"main": "server.ts",
	"engines": {
		"node": ">=24.14.0"
	},
	"type": "module",
	"scripts": {
		"start": "node ./dist/server.js",
		"start:prod": "node ./dist/server.js",
		"start:prod-openvidu2": "COM_MODULE=openvidu node ./dist/server.js",
		"docker:build": "docker build -t browser-emulator:local .",
		"docker:up": "docker compose up --build",
		"docker:down": "docker compose down",
		"build": "tsc",
		"docs": "pnpm exec redocly build-docs docs/openapi.yaml -o docs/index.html",
		"watch": "tsc -w",
		"lint": "eslint src tests dev_scripts --ext .ts",
		"lint:fix": "eslint src tests dev_scripts --ext .ts --fix",
		"format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.ts\" \"*.js\" \"*.json\"",
		"test": "vitest run --project=unit --project=integration --project=e2e",
		"test:unit": "vitest run --project=unit",
		"test:integration": "vitest run --project=integration",
		"test:e2e": "vitest run --project=e2e",
		"test:perf": "vitest run --project=perf",
		"test:qoe": "vitest run --project=qoe",
		"test:coverage": "vitest run --project=unit --project=integration --project=e2e --coverage",
		"test:legacy": "tsx ./dev_scripts/run-tests-vagrant.ts",
		"analyze:perf": "tsx ./dev_scripts/analyze-perf.ts",
		"compare:perf": "tsx ./dev_scripts/compare-perf.ts",
		"test:docker": "docker compose -f docker-compose.test.yml up --build --abort-on-container-exit --exit-code-from browser-emulator-tests",
		"qoe": "tsx ./src/qoe-cli.ts"
	},
	"author": "Carlos Santos & Iván Chicano",
	"license": "Apache 2.0",
	"dependencies": {
		"@aws-sdk/client-s3": "3.1073.0",
		"@aws-sdk/lib-storage": "3.1073.0",
		"@elastic/elasticsearch": "9.4.2",
		"async-mutex": "0.5.0",
		"awilix": "13.0.5",
		"dockerode": "5.0.1",
		"exit-hook": "5.1.0",
		"express": "5.2.1",
		"express-rate-limit": "8.5.2",
		"livekit-server-sdk": "2.15.5",
		"multer": "2.2.0",
		"node-os-utils": "2.0.3",
		"p-limit": "7.3.0",
		"pino": "10.3.1",
		"selenium-webdriver": "4.45.0",
		"ws": "8.21.0",
		"yargs": "18.0.0"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@redocly/cli": "2.34.0",
		"@testcontainers/elasticsearch": "12.0.3",
		"@testcontainers/s3mock": "12.0.3",
		"@tsconfig/node-ts": "23.6.4",
		"@tsconfig/node24": "24.0.4",
		"@types/dockerode": "4.0.1",
		"@types/express": "5.0.6",
		"@types/express-serve-static-core": "5.1.1",
		"@types/multer": "2.1.0",
		"@types/node": "25.3.2",
		"@types/selenium-webdriver": "4.35.6",
		"@types/supertest": "7.2.0",
		"@types/ws": "8.18.1",
		"@types/yargs": "17.0.35",
		"@typescript-eslint/eslint-plugin": "8.61.1",
		"@typescript-eslint/parser": "8.61.1",
		"@vitest/coverage-v8": "4.1.9",
		"eslint": "10.5.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-import-resolver-typescript": "4.4.5",
		"eslint-plugin-import": "2.32.0",
		"eslint-plugin-prettier": "5.5.6",
		"memfs": "4.57.8",
		"pino-pretty": "13.1.3",
		"prettier": "3.8.4",
		"supertest": "7.2.2",
		"testcontainers": "12.0.3",
		"ts-node": "10.9.2",
		"tsx": "4.22.4",
		"typescript": "6.0.3",
		"typescript-eslint": "8.61.1",
		"vitest": "4.1.9"
	},
	"packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
	"optionalDependencies": {
		"bufferutil": "4.1.0"
	}
}
