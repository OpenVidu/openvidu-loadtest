{
	"name": "browser-emulator",
	"version": "4.0.0",
	"description": "Load testing tool for OpenVidu",
	"main": "server.ts",
	"engines": {
		"node": ">=24.14.0"
	},
	"type": "module",
	"scripts": {
		"start:prod": "node ./dist/server.js",
		"start:prod-livekit": "COM_MODULE=livekit node ./dist/server.js",
		"start:dev": "APPLICATION_MODE=DEVELOPMENT ts-node ./src/server.ts",
		"build": "tsc",
		"watch": "tsc -w",
		"lint": "eslint src tests --ext .ts",
		"lint:fix": "eslint src tests --ext .ts --fix",
		"format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.ts\" \"*.js\" \"*.json\"",
		"test": "vitest",
		"test:unit": "vitest run --project=unit",
		"test:e2e": "vitest run --project=e2e",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest watch",
		"qoe": "ts-node ./src/utils/run-qoe-analysis.ts"
	},
	"author": "Carlos Santos & Iván Chicano",
	"license": "Apache 2.0",
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1000.0",
		"@aws-sdk/lib-storage": "^3.1000.0",
		"@elastic/elasticsearch": "9.3.2",
		"async-mutex": "^0.5.0",
		"awilix": "^13.0.1",
		"dockerode": "4.0.9",
		"exit-hook": "^5.1.0",
		"express": "5.2.1",
		"livekit-server-sdk": "^2.15.0",
		"multer": "2.1.0",
		"node-os-utils": "^2.0.1",
		"p-limit": "^7.3.0",
		"selenium-webdriver": "4.41.0",
		"ws": "^8.19.0",
		"yargs": "^18.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.3",
		"@tsconfig/node-ts": "^23.6.4",
		"@tsconfig/node24": "^24.0.4",
		"@types/dockerode": "4.0.1",
		"@types/express": "5.0.6",
		"@types/express-serve-static-core": "^5.1.1",
		"@types/multer": "^2.0.0",
		"@types/node": "25.3.2",
		"@types/selenium-webdriver": "4.35.5",
		"@types/supertest": "^7.2.0",
		"@types/ws": "^8.18.1",
		"@types/yargs": "^17.0.35",
		"@typescript-eslint/eslint-plugin": "^8.56.1",
		"@typescript-eslint/parser": "^8.56.1",
		"@vitest/coverage-v8": "^4.0.18",
		"eslint": "^9.39.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-prettier": "^5.5.5",
		"memfs": "^4.56.10",
		"prettier": "3.8.1",
		"supertest": "^7.2.2",
		"ts-node": "10.9.2",
		"typescript": "5.9.3",
		"typescript-eslint": "^8.56.1",
		"vitest": "^4.0.18"
	},
	"packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
	"optionalDependencies": {
		"bufferutil": "^4.1.0"
	}
}
