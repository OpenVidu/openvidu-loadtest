# -*- mode: ruby -*-
# vi: set ft=ruby :
qoe = ENV['QOE'] || 'true'
memory = ENV['MEMORY'] || 4096
cpus = ENV['CPUS'] || 12
provider = ENV['VAGRANT_PROVIDER'] || 'virtualbox'

Vagrant.configure("2") do |config|
  config.ssh.forward_agent = true
  config.vm.box = "cloud-image/ubuntu-24.04"

  config.vm.disk :disk, size: "20GB", primary: true

  config.vm.network "forwarded_port", guest: 5000, host: 5000, host_ip: "127.0.0.1"
  config.vm.network "forwarded_port", guest: 5900, host: 5900, host_ip: "127.0.0.1"

  config.vm.provision "shell", inline: <<-SHELL
    mkdir -p /opt/openvidu-loadtest/browser-emulator
    chown -R vagrant:vagrant /opt/openvidu-loadtest
  SHELL

  synced_folders = [
    "./src:/opt/openvidu-loadtest/browser-emulator/src",
    "./tests:/opt/openvidu-loadtest/browser-emulator/tests",
    "./qoe_scripts:/opt/openvidu-loadtest/browser-emulator/qoe_scripts",
    "./recordings:/opt/openvidu-loadtest/browser-emulator/recordings",
    "./prepare_scripts:/opt/openvidu-loadtest/browser-emulator/prepare_scripts",
    "./public:/opt/openvidu-loadtest/browser-emulator/public",
    "./public-lk:/opt/openvidu-loadtest/browser-emulator/public-lk",
    "./stats:/opt/openvidu-loadtest/browser-emulator/stats",
  ]
  synced_folders.each do |folder|
    config.vm.synced_folder folder.split(':')[0], folder.split(':')[1]
  end

  files_to_provision = [
    "./package.json:/opt/openvidu-loadtest/browser-emulator/package.json",
    "./pnpm-lock.yaml:/opt/openvidu-loadtest/browser-emulator/pnpm-lock.yaml",
    "./pnpm-workspace.yaml:/opt/openvidu-loadtest/browser-emulator/pnpm-workspace.yaml",
    "./tsconfig.json:/opt/openvidu-loadtest/browser-emulator/tsconfig.json",
    "./vitest.config.ts:/opt/openvidu-loadtest/browser-emulator/vitest.config.ts",
    "./tsconfig.test.json:/opt/openvidu-loadtest/browser-emulator/tsconfig.test.json",
    "./eslint.config.js:/opt/openvidu-loadtest/browser-emulator/eslint.config.js",
    "./.prettierrc:/opt/openvidu-loadtest/browser-emulator/.prettierrc",
    './.prettierignore:/opt/openvidu-loadtest/browser-emulator/.prettierignore',
    './tsconfig.dev_scripts.json:/opt/openvidu-loadtest/browser-emulator/tsconfig.dev_scripts.json',
  ]
  files_to_provision.each do |file|
    config.vm.provision "file", source: file.split(':')[0], destination: file.split(':')[1]
  end

  config.vm.provider provider do |vb|
    vb.memory = memory
    vb.cpus = cpus
    vb.customize ["modifyvm", :id, "--natdnshostresolver1", "on", "--usb", "off", "--usbehci", "off", "--usb-xhci", "off"]
  end

  config.vm.provision "shell", :path => "vagrant_create_box_provision.sh", :args => [qoe]
end
